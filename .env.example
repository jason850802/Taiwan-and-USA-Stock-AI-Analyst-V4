# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FAST=gemini-3.5-flash
GEMINI_MODEL_THINKING=gemini-3.1-pro-preview

# FinMind（選填）：填 token 可提高額度；未填使用公開額度
FINMIND_TOKEN=

# Upstash Redis（選填但 production 建議設定）：供 /api/* 跨 serverless 實例限流使用
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 後端共享密鑰：隨機字串，例如 openssl rand -hex 24
PROXY_SHARED_SECRET=

# 前端共享密鑰：須與 PROXY_SHARED_SECRET 同值
# 注意：VITE_ 變數會被打包進前端 dist，這是提高門檻用，不是機密。
# GEMINI_API_KEY 絕不可加 VITE_、不可進 bundle；兩者用途刻意區分。
VITE_PROXY_SECRET=

# 允許呼叫 /api/* 的前端來源（Vite 與 Vercel 本地開發；部署後回填實際 production 網域）
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3001

# LLM provider 分流（僅本機 vercel dev 用；Vercel 部署不設此變數 → 永遠 gemini-api）
# 可選值：gemini-api（預設，未設同義）｜claude-cli（走本機 Claude Code CLI，吃 Claude 訂閱，
# 需先在終端跑一次 `claude /login` 完成登入）
LLM_PROVIDER=

# 選填：claude.exe 完整路徑；未設時自動探索 PATH 與 %APPDATA%\Claude\claude-code 最高版本目錄
CLAUDE_CLI_PATH=

# 選填：claude-cli 路徑的模型別名（預設 fast→sonnet、thinking→opus）
CLAUDE_CLI_MODEL_FAST=
CLAUDE_CLI_MODEL_THINKING=
